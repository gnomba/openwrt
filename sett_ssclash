mode: rule # режим работы по правилам
tproxy-port: 7894 # порт прозрачного прокси
ipv6: false # выключаем IPv6
log-level: error # уровень предупреждений в журнале
allow-lan: true # если true, можно открыть SOCKS5 для ваших устройств
unified-delay: true # серверы пингуются по два раза, показывая лучшую скорость
tcp-concurrent: true # ускоряет работу
external-controller: 0.0.0.0:9090 # адрес Dashboard панели Clash
external-ui: ./ui # папка, в которую Clash качает файлы панели
#secret: "Kruto!P@ro11" # пароль на панель можно менять
external-ui-url: "https://github.com/Zephyruso/zashboard/releases/latest/download/dist-cdn-fonts.zip" # ссылка позволяет обновлять панель

dns:
  enable: true
  listen: 0.0.0.0:7874          # DNS-порт mihomo
  ipv6: false
  enhanced-mode: fake-ip
  fake-ip-filter-mode: rule
  fake-ip-range: 198.18.0.0/15
  fake-ip-filter:
    # Эти списки идут через opera-proxy → им НЕ нужен fake-ip
    - RULE-SET,file-user-list-proxy,real-ip
    - RULE-SET,block,real-ip
    - RULE-SET,geoblock,real-ip
    - RULE-SET,twitter,real-ip
    - RULE-SET,hdrezka,real-ip
    - RULE-SET,tiktok,real-ip
    - RULE-SET,google_ai,real-ip
    # Эти списки идут через AWG → им нужен fake-ip
    - RULE-SET,file-user-list-warp,fake-ip
    - RULE-SET,youtube,fake-ip
    - RULE-SET,telegram,fake-ip
    - RULE-SET,meta,fake-ip
    #- RULE-SET,whatsapp_cidr_ipv4,fake-ip
    # Всё остальное (ya.ru, vk.com, обычные сайты) — реальный IP
    - MATCH,real-ip
  default-nameserver:
    - 8.8.4.4
    - 8.8.8.8
    - 1.0.0.1
    - 1.1.1.1
    - 77.88.8.8
    - 77.88.8.1
    - 9.9.9.9
    - 149.112.112.112
  nameserver:
    - https://8.8.8.8/dns-query
    - tls://8.8.8.8
    - https://cloudflare-dns.com/dns-query
    - tls://1dot1dot1dot1.cloudflare-dns.com
    - https://common.dot.dns.yandex.net
    - tls://common.dot.dns.yandex.net
    - https://dns.quad9.net/dns-query
    - tls://dns.quad9.net
  rules:
    - QUERY-TYPE,HTTPS,REJECT
    - DOMAIN-SUFFIX,use-application-dns.net,REJECT

tun:
  enable: false

sniffer:
  enable: false                 # обязательно отключено

profile:
  store-selected: true
  store-fake-ip: true

routing-mark: 2 # необходимо помечать траффик, которым управляет Clash для маршрутизации по правилам

proxies:
  - name: opera-proxy
    type: http
    server: 127.0.0.1
    port: 18080
    udp: true
#  - name: dumbproxy
#    type: http
#    server: 127.0.0.1
#    port: 8080
#    udp: true

proxy-groups:
  - name: OPERA_PROXY
    type: select
    proxies:
      - opera-proxy
      - DIRECT
  - name: AWG_WARP
    type: select
    proxies:
      - DIRECT
#  - name: DUMBPROXY
#    type: select
#    proxies:
#      - dumbproxy
#      - DIRECT

