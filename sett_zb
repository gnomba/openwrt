settings_commit(){
uci commit zeroblock
uci commit
/etc/init.d/zeroblock restart
sleep 3
/etc/init.d/zeroblock reload
sleep 3
/etc/init.d/sing-box reload
}

settings_detect(){
dmesg | grep -i 'Machine model:' | awk -F: '{print $2}' | sed 's/ //'
}

if [[ "$(ubus call system board | jq -r .board_name | awk -F',' '{print $1}')" == "routerich" ]]; then
	echo "┌──────────┐"
	echo "│ DETECTED │ $(settings_detect) => API v2"
	echo "└──────────┘ "
    settings_rr
else
	echo "┌──────────┐"
	echo "│ DETECTED │ $(settings_detect) => API v1"
	echo "└──────────┘ "
    settings_non_rr
fi

settings_commit

exit 0
